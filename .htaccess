# ============================================================
# Couveuse PAPRICAI — .htaccess
# Sécurité, performance, SEO
# ============================================================

Options -Indexes

# ─── HTTPS + www redirect ─────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forcer HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Forcer non-www
  RewriteCond %{HTTP_HOST} ^www\.couveuse-papricai\.org [NC]
  RewriteRule ^(.*)$ https://couveuse-papricai.org/$1 [R=301,L]
</IfModule>

# ─── Headers de sécurité ─────────────────────────────────────────────────────
<IfModule mod_headers.c>

  # Empêche le clickjacking (l'intégration du site dans une iframe malveillante)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Empêche le MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Politique de référent : envoie l'origine sur HTTPS, rien en cross-origin HTTP
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Désactive les fonctionnalités sensibles du navigateur
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # HSTS — Force HTTPS pour 1 an
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # CSP — Politique de sécurité du contenu
  # unsafe-inline nécessaire pour les <style> inline dans les pages
  Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://api.fontshare.com; font-src 'self' https://fonts.gstatic.com https://api.fontshare.com; img-src 'self' data: https:; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://e-papricai.vercel.app"

  # Supprime les informations serveur des headers
  Header unset X-Powered-By
  Header unset Server

</IfModule>

# ─── Compression Gzip ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ─── Cache navigateur ────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — 1 heure (contenu pouvant changer)
  ExpiresByType text/html "access plus 1 hour"

  # CSS et JS — 1 an (fichiers versionnés ou rarement changés)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"

  # Images — 1 an
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Polices — 1 an
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|woff|jpg|jpeg|png|webp|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ─── Types MIME manquants ────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType application/manifest+json .webmanifest
</IfModule>

# ─── Page d'erreur 404 ───────────────────────────────────────────────────────
ErrorDocument 404 /index.html
